# ─────────────────────────────────────────────────────────────────────────────
# wiki-llm — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores necessários.
# ─────────────────────────────────────────────────────────────────────────────

# Backend LLM: bedrock | openrouter | openai | ollama
WIKI_BACKEND=openrouter

# Modelo padrão (usado por todos os estágios, salvo override no config)
WIKI_MODEL_ID=mistralai/mistral-7b-instruct:free

# ─── OpenRouter ──────────────────────────────────────────────────────────────
OPENROUTER_APIKEY=sk-or-...
# Opcional — padrão: https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── AWS Bedrock ─────────────────────────────────────────────────────────────
# AWS_LOGINKEY=<bearer token IAM Identity Center>
# WIKI_BEDROCK_REGION=sa-east-1

# ─── Caminhos (opcionais — padrões em config/exemplo_normas.py) ──────────────
# WIKI_DIR=wiki
# LOG_DIR=logs
# CONTENT_DIR=content_new

# ─── UI NiceGUI ──────────────────────────────────────────────────────────────
# WIKI_UI_HOST=0.0.0.0
# WIKI_UI_PORT=8080
# WIKI_UI_STORAGE_SECRET=troque-por-segredo-unico
