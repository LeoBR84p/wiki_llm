"""wiki-llm configuration — generated by the setup wizard."""

from __future__ import annotations

import os
from pathlib import Path

from dotenv import load_dotenv

from src.models.config import (
    ObjectTypeConfig,
    GroupConfig,
    LLMConfig,
    KeyThemeConfig,
    WikiConfig,
)
from src.readers.base import MarkItDownPdfReader

load_dotenv()

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

_ROOT    = Path(__file__).parent.parent
_PROMPTS = _ROOT / 'config' / 'prompts'

WIKI_DIR    = Path(os.environ.get('WIKI_DIR', str(_ROOT / 'wiki')))
LOG_DIR     = Path(os.environ.get('LOG_DIR', str(_ROOT / 'logs')))
CONTENT_DIR = Path(os.environ.get('CONTENT_DIR', str(_ROOT / 'content_new')))

# ---------------------------------------------------------------------------
# Main settings  (override via environment variables or edit directly)
# ---------------------------------------------------------------------------

_BACKEND  = os.environ.get('WIKI_BACKEND',  'openrouter')
_MODEL_ID = os.environ.get('WIKI_MODEL_ID', 'll')
_LANGUAGE = os.environ.get('WIKI_LANGUAGE', 'english')

# ---------------------------------------------------------------------------
# WikiConfig
# ---------------------------------------------------------------------------

config = WikiConfig(
    wiki_name='My Wiki',
    wiki_dir=WIKI_DIR,
    log_dir=LOG_DIR,
    language=_LANGUAGE,
    llm=LLMConfig(
        backend=_BACKEND,  # type: ignore[arg-type]
        model_id=_MODEL_ID,
        temperature=0.2,
        max_tokens=4096,
    ),
    objects=[
        ObjectTypeConfig(
            name='sd',
            slug='sd',
            wiki_subdir='sd',
            prompt_generate=_PROMPTS / 'wiki_summary_sd.md',
            prompt_evaluate=_PROMPTS / 'wiki_evaluate_sd.md',
            frontmatter_fields=[],
            max_rounds=2,
        ),
    ],
    key_themes=[
        KeyThemeConfig(
            name='topics',
            wiki_subdir='topics',
            term_source='metadata_field',
            metadata_field='section',
            prompt_normalize=_PROMPTS / 'wiki_topics_normalize.md',
            prompt_create_page=_PROMPTS / 'wiki_agent_create_topics.md',
        ),
    ],
    groups=[],
    prompt_editor=_PROMPTS / 'wiki_editor.md',
    prompt_lint=_PROMPTS / 'wiki_lint.md',
    prompt_consolidate=_PROMPTS / 'wiki_consolidate_themes.md',
    prompt_chat=_PROMPTS / 'wiki_chat.md',
    status_filter=[],
    max_chars_input=80_000,
    on_llm_error='skip',
    export_word=False,
    content_dir=CONTENT_DIR,
    pdf_reader=MarkItDownPdfReader(),
)
